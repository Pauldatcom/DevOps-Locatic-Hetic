@model Locatic.ViewModels.CarViewModel

<h1>Ajouter une voiture</h1>

<form asp-action="Create" method="post" enctype="multipart/form-data">

    <div class="mb-3">
        <label asp-for="RegistrationNumber" class="form-label"></label>
        <input asp-for="RegistrationNumber" class="form-control" />
        <span asp-validation-for="RegistrationNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Year" class="form-label"></label>
        <input asp-for="Year" class="form-control" />
        <span asp-validation-for="Year" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="NumberOfPlaces" class="form-label"></label>
        <input asp-for="NumberOfPlaces" class="form-control" />
        <span asp-validation-for="NumberOfPlaces" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PricePerDay" class="form-label"></label>
        <input asp-for="PricePerDay" class="form-control" />
        <span asp-validation-for="PricePerDay" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FuelType" class="form-label"></label>
        <input asp-for="FuelType" class="form-control" />
        <span asp-validation-for="FuelType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ModeleId" class="form-label">Modèle</label>
        <select asp-for="ModeleId"
                asp-items="ViewBag.Modeles"
                class="form-control">
            <option value="">-- Choisir un modèle --</option>
        </select>
    </div>
   <div class="mb-3">
    <label asp-for="ImageFile" class="form-label">Image</label>
    <input asp-for="ImageFile" type="file" class="form-control" />
</div>

    <button type="submit" class="btn btn-success">
        Enregistrer
    </button>

</form>