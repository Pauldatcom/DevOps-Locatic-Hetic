@model Locatic.ViewModels.CarViewModel

<h1>Détails de la voiture</h1>

<div class="card">
    <div class="card-body">

        <p>
            <strong>Immatriculation :</strong>
            @Model.RegistrationNumber
        </p>

        <p>
            <strong>Année :</strong>
            @Model.Year
        </p>

        <p>
            <strong>Nombre de places :</strong>
            @Model.NumberOfPlaces
        </p>

        <p>
            <strong>Tarif journalier :</strong>
            @Model.PricePerDay €
        </p>

        <p>
            <strong>Carburant :</strong>
            @Model.FuelType
        </p>

        <p>
            <strong>Modèle :</strong>
            @Model.Modele.Name
        </p>

        <p>
            <strong>Marque :</strong>
            @Model.Modele.Brand.Name
        </p>

        <p>
            <strong>Image :</strong>
        </p>
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Modele?.Name" class="img-fluid rounded" style="max-height: 300px;" />
        }
        else
        {
            <p class="text-muted">Aucune image</p>
        }

    </div>
</div>

<br />

<a asp-action="Index" class="btn btn-secondary">
    Retour
</a>