@model ReservationBookViewModel

@{
    ViewData["Title"] = "Réserver";
    var placeholderImage = "https://placehold.co/600x400/e8eef5/64748b?text=Locatic";
    var imageUrl = string.IsNullOrWhiteSpace(Model.ImageUrl) ? placeholderImage : Model.ImageUrl;
}

<section class="book-page">
    <div class="container">
        <a asp-controller="Home" asp-action="Index" class="back-link">← Retour au catalogue</a>

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="book-car-preview">
                    <img src="@imageUrl"
                         alt="@Model.BrandName @Model.CarName"
                         class="book-car-image"
                         onerror="this.src='@placeholderImage'" />
                    <div class="book-car-info">
                        <span class="car-card-brand">@Model.BrandName</span>
                        <h2>@Model.CarName</h2>
                        <div class="car-card-specs">
                            <span class="spec-tag">@Model.Year</span>
                            <span class="spec-tag">@Model.FuelType</span>
                            <span class="spec-tag">@Model.NumberOfPlaces places</span>
                        </div>
                        <div class="book-price-highlight">
                            <span class="price-amount" id="pricePerDay">@Model.PricePerDay.ToString("0")</span>
                            <span class="price-unit">€ / jour</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="book-form-card">
                    <h1>Finaliser votre réservation</h1>
                    <p class="book-form-subtitle">Remplissez le formulaire ci-dessous pour confirmer votre location.</p>

                    <form asp-action="Book" method="post" id="bookForm">
                        <input type="hidden" asp-for="CarId" />
                        <input type="hidden" asp-for="PricePerDay" id="hiddenPricePerDay" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <h5 class="form-section-title">Période de location</h5>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label"></label>
                                <input asp-for="StartDate" type="date" class="form-control form-control-lg" id="startDate" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label"></label>
                                <input asp-for="EndDate" type="date" class="form-control form-control-lg" id="endDate" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="price-summary mb-4" id="priceSummary">
                            <div class="price-summary-row">
                                <span>Durée</span>
                                <strong id="durationDays">—</strong>
                            </div>
                            <div class="price-summary-row total">
                                <span>Total estimé</span>
                                <strong id="totalPrice">—</strong>
                            </div>
                        </div>

                        <h5 class="form-section-title">Vos coordonnées</h5>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label"></label>
                                <input asp-for="FirstName" class="form-control form-control-lg" placeholder="Jean" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label"></label>
                                <input asp-for="LastName" class="form-control form-control-lg" placeholder="Dupont" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="jean.dupont@email.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label"></label>
                                <input asp-for="PhoneNumber" class="form-control form-control-lg" placeholder="06 12 34 56 78" />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-reserve btn-reserve-lg w-100">
                            Confirmer la réservation
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const startInput = document.getElementById('startDate');
            const endInput = document.getElementById('endDate');
            const pricePerDay = parseFloat(document.getElementById('hiddenPricePerDay').value) || 0;
            const durationEl = document.getElementById('durationDays');
            const totalEl = document.getElementById('totalPrice');

            function updatePrice() {
                if (!startInput.value || !endInput.value) {
                    durationEl.textContent = '—';
                    totalEl.textContent = '—';
                    return;
                }

                const start = new Date(startInput.value);
                const end = new Date(endInput.value);
                let days = Math.ceil((end - start) / (1000 * 60 * 60 * 24));

                if (days <= 0) {
                    durationEl.textContent = 'Dates invalides';
                    totalEl.textContent = '—';
                    return;
                }

                const total = days * pricePerDay;
                durationEl.textContent = days + (days > 1 ? ' jours' : ' jour');
                totalEl.textContent = total.toFixed(0) + ' €';
            }

            startInput.addEventListener('change', updatePrice);
            endInput.addEventListener('change', updatePrice);
            updatePrice();
        });
    </script>
}
